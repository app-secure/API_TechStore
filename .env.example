Firebase__Enabled=true
Firebase__ProjectId=tu-firebase-project-id
Firebase__ApiKey=tu-firebase-api-key

# ─── BASE DE DATOS ─────────────────────────────────────────────────────────────
# Acepta formato URI: postgres://user:pass@host:port/db?sslmode=require
# O formato Npgsql: Host=...;Port=5432;Database=...;Username=...;Password=...
DATABASE_URL=postgres://usuario:password@host:5432/database?sslmode=require

# ─── BREVO (email transaccional) ──────────────────────────────────────────────
# Obtener en: https://app.brevo.com/settings/keys/api
ExternalServices__Brevo__ApiKey=tu-brevo-api-key
ExternalServices__Brevo__SenderEmail=noreply@tudominio.com
ExternalServices__Brevo__SenderName=TechStore360
# URL de plantilla Brevo (para notificaciones de compra en Crear endpoint)
ExternalServices__Brevo__ApiUrl=https://api.brevo.com/v3/smtp/email

# ─── EMAIL SMTP (fallback si Brevo falla) ─────────────────────────────────────
# Para Gmail: Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM=TechStore360 <tucorreo@gmail.com>

# ─── FRONTEND ─────────────────────────────────────────────────────────────────
# URL del front-end. El QR generado apunta a {FRONTEND_URL}/compras/{numero}
# Si se deja vacío, el QR solo contiene el número de factura.
FRONTEND_URL=http://192.168.1.100:3000
